## Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vectorai

## Embedding Model (CLIP)
EMBEDDING_MODEL=ViT-B-32
BATCH_SIZE=32

## Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=vectorai-index
PINECONE_HOST=https://your-index-host.pinecone.io

## API Server
API_HOST=0.0.0.0
API_PORT=8000
